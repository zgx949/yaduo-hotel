generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  username    String       @unique
  name        String
  password    String
  role        String
  status      String
  permissions Json
  createdAt   DateTime     @default(now())
  approvedAt  DateTime?
  orderGroups OrderGroup[]
  sessions    Session[]
}

model Session {
  token     String   @id
  userId    String
  role      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PoolAccount {
  id                  String      @id @default(cuid())
  phone               String
  loginTokenCipher    String?
  remark              String?
  isEnabled           Boolean     @default(true)
  isOnline            Boolean     @default(false)
  isPlatinum          Boolean     @default(false)
  isNewUser           Boolean     @default(false)
  corporateAgreements Json
  points              Int         @default(0)
  breakfastCoupons    Int         @default(0)
  roomUpgradeCoupons  Int         @default(0)
  lateCheckoutCoupons Int         @default(0)
  slippersCoupons     Int         @default(0)
  dailyOrdersLeft     Int         @default(0)
  lastExecution       Json
  lastResult          Json
  discountCouponAssets Json?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  orderItems          OrderItem[]
}

model OrderGroup {
  id            String      @id @default(cuid())
  bizOrderNo    String      @unique
  chainId       String
  hotelName     String
  customerName  String
  contactPhone  String?
  checkInDate   DateTime
  checkOutDate  DateTime
  totalNights   Int
  totalAmount   Float       @default(0)
  currency      String      @default("CNY")
  status        String
  paymentStatus String
  creatorId     String
  creatorName   String
  remark        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  creator       User        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  @@index([creatorId, createdAt])
  @@index([status, paymentStatus])
}

model OrderItem {
  id                 String       @id @default(cuid())
  groupId            String
  atourOrderId       String?      @unique
  bookingTier        String?
  roomTypeId         String?
  rateCode           String?
  rateCodeId         String?
  rpActivityId       String?
  rateCodePriceType  String?
  rateCodeActivities String?
  remark             String?
  breakfastCount     Int          @default(0)
  roomLevelUpCount   Int          @default(0)
  delayedCheckOutCount Int        @default(0)
  shooseCount        Int          @default(0)
  roomType           String
  roomCount          Int          @default(1)
  accountId          String?
  accountPhone       String?
  checkInDate        DateTime
  checkOutDate       DateTime
  amount             Float        @default(0)
  status             String
  paymentStatus      String
  executionStatus    String
  splitIndex         Int          @default(1)
  splitTotal         Int          @default(1)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  account            PoolAccount? @relation(fields: [accountId], references: [id])
  group              OrderGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tasks              Task[]
  invoiceRecord      InvoiceRecord?

  @@index([groupId, splitIndex])
  @@index([accountId])
  @@index([status, paymentStatus])
}

model InvoiceTemplate {
  id               String   @id @default(cuid())
  invoiceId        Int      @unique
  invoiceName      String
  invoiceType      Int      @default(13)
  invoiceTitleType Int      @default(2)
  taxNo            String?
  address          String?
  telephone        String?
  bank             String?
  account          String?
  email            String?
  remark           String?
  isEnabled        Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  records          InvoiceRecord[]

  @@index([invoiceName])
  @@index([createdAt])
}

model InvoiceRecord {
  id               String          @id @default(cuid())
  orderItemId      String          @unique
  orderGroupId     String
  invoiceTemplateId String
  invoiceId        Int
  orderId          String?
  chainId          String
  invoiceType      Int
  invoiceTitleType Int
  invoiceName      String
  taxNo            String?
  email            String?
  state            String          @default("PENDING")
  stateDesc        String?
  submittedPayload Json?
  responsePayload  Json?
  errorMessage     String?
  issuedAt         DateTime?
  createdBy        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  orderItem        OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  template         InvoiceTemplate @relation(fields: [invoiceTemplateId], references: [id], onDelete: Restrict)

  @@index([orderGroupId, createdAt])
  @@index([invoiceTemplateId])
  @@index([state])
}

model Task {
  id          String    @id @default(cuid())
  orderItemId String
  state       String
  progress    Int       @default(0)
  error       String?
  result      Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId, createdAt])
}

model BlacklistRecord {
  id         String   @id @default(cuid())
  chainId    String
  hotelName  String
  severity   String
  reason     String
  tags       Json
  status     String
  reportedBy String
  reporterId String?
  source     String
  date       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chainId, hotelName])
}

model SystemConfig {
  id                     String      @id @default("default")
  siteName               String
  supportContact         String
  maintenanceMode        Boolean     @default(false)
  maintenanceMessage     String
  enableNewUser          Boolean     @default(true)
  enablePlatinum         Boolean     @default(true)
  enableCorporate        Boolean     @default(true)
  disabledCorporateNames Json
  llmModels              LlmModel[]
  proxies                ProxyNode[]
}

model TaskModuleConfig {
  id          String   @id @default(cuid())
  moduleId    String   @unique
  name        String
  category    String
  queueName   String
  enabled     Boolean  @default(true)
  schedule    String?
  concurrency Int      @default(1)
  attempts    Int      @default(3)
  backoffMs   Int      @default(3000)
  useProxy    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskRun {
  id           String    @id @default(cuid())
  moduleId     String
  queueName    String
  jobId        String
  state        String
  attemptsMade Int       @default(0)
  progress     Int       @default(0)
  payload      Json
  result       Json?
  error        String?
  orderGroupId String?
  orderItemId  String?
  proxyId      String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([queueName, jobId])
  @@index([moduleId, createdAt])
  @@index([queueName, state])
}

model ProxyNode {
  id           String       @id @default(cuid())
  configId     String
  host         String
  port         Int
  type         String
  status       String
  authEnabled  Boolean      @default(false)
  authUsername String       @default("")
  authPassword String       @default("")
  lastChecked  DateTime     @default(now())
  location     String
  failCount    Int          @default(0)
  config       SystemConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model LlmModel {
  id           String       @id @default(cuid())
  configId     String
  name         String
  provider     String
  modelId      String
  apiKey       String
  systemPrompt String
  baseUrl      String
  temperature  Float        @default(0.2)
  maxTokens    Int          @default(1024)
  isActive     Boolean      @default(false)
  config       SystemConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model OtaHotel {
  id              String      @id @default(cuid())
  platform        String
  platformHotelId String
  hotelName       String
  city            String?
  status          String
  source          String      @default("SYNC")
  rawPayload      Json?
  lastSyncedAt    DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  rooms           OtaRoomType[]

  @@unique([platform, platformHotelId])
  @@index([platform, updatedAt])
}

model OtaRoomType {
  id                 String    @id @default(cuid())
  platform           String
  platformHotelId    String
  platformRoomTypeId String
  roomTypeName       String
  bedType            String?
  gid                String?
  rpid               String?
  outRid             String?
  rateplanCode       String?
  vendor             String?
  rawPayload         Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  hotelId            String
  hotel              OtaHotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([platform, platformHotelId, platformRoomTypeId])
  @@index([platform, platformHotelId])
}

model OtaHotelMapping {
  id               String   @id @default(cuid())
  platform         String
  platformHotelId  String
  shid             String?
  platformHotelName String
  internalChainId  String
  internalHotelName String
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([platform, platformHotelId])
  @@index([platform, enabled])
}

model OtaRoomMapping {
  id                  String   @id @default(cuid())
  platform            String
  platformHotelId     String
  platformRoomTypeId  String
  srid                String?
  platformRoomTypeName String
  internalRoomTypeId  String
  internalRoomTypeName String
  rateCode            String
  rateCodeId          String?
  rpActivityId        String?
  breakfastCount      Int      @default(0)
  guaranteeType       Int      @default(0)
  cancelPolicyCal     Json?
  publishStatus       String   @default("DRAFT")
  lastPublishedAt     DateTime?
  lastPublishError    String?
  bookingTier         String
  platformChannel     String
  orderSubmitMode     String
  autoOrderEnabled    Boolean  @default(true)
  autoSyncEnabled     Boolean  @default(true)
  manualTuningEnabled Boolean  @default(false)
  autoSyncFutureDays  Int      @default(30)
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([platform, platformHotelId, platformRoomTypeId, platformChannel, rateCode])
  @@index([platform, enabled])
}

model OtaChannelMapping {
  id                 String   @id @default(cuid())
  platform           String
  platformChannel    String
  internalBookingTier String
  internalChannelName String
  autoSubmit         Boolean  @default(false)
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([platform, platformChannel])
  @@index([platform, enabled])
}

model OtaCalendarItem {
  id                 String   @id @default(cuid())
  platform           String
  platformHotelId    String
  platformRoomTypeId String
  platformChannel    String   @default("DEFAULT")
  rateplanCode       String
  date               String
  price              Int      @default(0)
  inventory          Int      @default(0)
  currency           String   @default("CNY")
  source             String   @default("MANUAL")
  lastPushedAt       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([platform, platformHotelId, platformRoomTypeId, platformChannel, rateplanCode, date])
  @@index([platform, date])
}

model OtaInboundOrder {
  id                 String   @id @default(cuid())
  platform           String
  externalOrderId    String
  status             String
  platformHotelId    String
  platformRoomTypeId String
  platformChannel    String
  customerName       String
  contactPhone       String?
  checkInDate        String
  checkOutDate       String
  roomCount          Int      @default(1)
  amount             Int      @default(0)
  currency           String   @default("CNY")
  remark             String?
  rawPayload         Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([platform, externalOrderId])
  @@index([platform, status])
}

model OtaOrderBinding {
  id                 String   @id @default(cuid())
  platform           String
  externalOrderId    String
  localOrderId       String?
  templatePayload    Json?
  autoSubmitState    String
  manualPaymentState String
  bookingConfirmState String
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([platform, externalOrderId])
  @@index([platform, autoSubmitState])
}

model OtaSyncLog {
  id        String   @id @default(cuid())
  type      String
  platform  String
  result    Json?
  createdAt DateTime @default(now())

  @@index([platform, createdAt])
}
